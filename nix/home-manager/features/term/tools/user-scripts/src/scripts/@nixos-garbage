#!/usr/bin/env bash

set -euo pipefail

KEEP="${1:-10}"
PROFILE="/nix/var/nix/profiles/system"

if ! [[ "$KEEP" =~ ^[0-9]+$ ]] || [ "$KEEP" -lt 1 ]; then
    echo "Usage: $0 <nombre_de_generations_a_conserver>"
    exit 1
fi

mapfile -t GENERATIONS < <(
    sudo nix-env --list-generations --profile "$PROFILE" |
        awk '{print $1}' |
        sort -n
)

COUNT="${#GENERATIONS[@]}"

if [ "$COUNT" -le "$KEEP" ]; then
    echo "Rien à supprimer: $COUNT génération(s), conservation demandée: $KEEP"
    exit 0
fi

DELETE_COUNT=$((COUNT - KEEP))
TO_DELETE=("${GENERATIONS[@]:0:DELETE_COUNT}")

echo "Générations à supprimer: ${TO_DELETE[*]}"
sudo nix-env --delete-generations --profile "$PROFILE" "${TO_DELETE[@]}"

echo "Lancement du garbage collector..."
sudo nix-store --gc

echo "OK. Générations restantes:"
sudo nix-env --list-generations --profile "$PROFILE"
